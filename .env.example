# ==========================================================
# VARIÁVEIS DE AMBIENTE — BRT Controle de Estoque
# Copie para .env (local) ou configure no Railway (produção).
# NÃO comite o .env real nem chaves de verdade.
# ==========================================================

# ---- Servidor ----
# Em produção o Railway define PORT automaticamente. Local usa 3000.
PORT=3000

# Chave da API pública de integração (o brt desenrola envia em x-api-key).
# GERE UMA CHAVE FORTE em produção (ex.: openssl rand -hex 32).
API_KEY=troque-esta-chave-por-uma-forte

# ---- Integrações em cloud ----
# Desligue WhatsApp e voz em Railway (evita travar o boot).
ENABLE_WHATSAPP=false

# ---- MeEventos ----
MEEVENTOS_API_KEY=
MEEVENTOS_BASE_URL=https://app1.meeventos.com.br/brt/api/v1
MEEVENTOS_USUARIO=
MEEVENTOS_SENHA=
MEEVENTOS_COOKIE_MANUAL=

# ---- Mark AI (Gemini) ----
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# ---- Google Cloud TTS (opcional; voz não roda em Railway) ----
GOOGLE_CLOUD_KEY_FILE=./google-cloud-key.json

# ---- GitHub Sync (opcional) ----
GITHUB_TOKEN=
GITHUB_REPO=
GITHUB_BRANCH=main
