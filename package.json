{
  "name": "brt-controle-estoque",
  "version": "1.0.0",
  "description": "Sistema de Controle de Estoque BRT Audiovisual com Mark AI",
  "main": "server.js",
  "bin": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "build": "pkg . --targets node18-win-x64,node18-linux-x64 --output dist/BRT-Audiovisual",
    "build:win": "pkg . --targets node18-win-x64 --output dist/windows/BRT-Audiovisual-win.exe",
    "build:linux": "pkg . --targets node18-linux-x64 --output dist/linux/BRT-Audiovisual-linux",
    "package": "node scripts/package.js"
  },
  "pkg": {
    "scripts": [
      "agent/**/*.js",
      "modules/**/*.js",
      "services/**/*.js"
    ],
    "targets": [
      "node18-win-x64",
      "node18-linux-x64"
    ],
    "outputPath": "dist"
  },
  "keywords": [
    "estoque",
    "qr-code",
    "audiovisual"
  ],
  "author": "BRT Audiovisual",
  "license": "ISC",
  "dependencies": {
    "@google-cloud/text-to-speech": "^5.5.0",
    "@google/generative-ai": "^0.24.1",
    "axios": "^1.13.5",
    "canvas": "^3.2.1",
    "chart.js": "^4.5.1",
    "chartjs-node-canvas": "^5.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.1",
    "json2csv": "^6.0.0-alpha.2",
    "node-cron": "^3.0.3",
    "node-notifier": "^10.0.1",
    "puppeteer": "^24.36.1",
    "qrcode-terminal": "^0.12.0",
    "whatsapp-web.js": "^1.34.6"
  },
  "devDependencies": {
    "nodemon": "^3.1.11"
  }
}
