app.get('/api/eventos', (req, res) => {
    try {
        const data = JSON.parse(fs.readFileSync('logs/eventos_completos.json', 'utf-8'));
        res.json(data);
    } catch (error) {
        res.status(500).json({ error: error.message });
    }
});

